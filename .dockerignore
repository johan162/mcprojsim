# Keep the build context as small as possible.
# The Dockerfile only needs these files for the current image build.
*

# Required build metadata
!.dockerignore
!Dockerfile
!pyproject.toml
!mkdocs.yml
!poetry.lock
!README.md
!CHANGELOG.md

# Application source
!src/
!src/**
!docs/
!docs/**
!assets/
!assets/**

